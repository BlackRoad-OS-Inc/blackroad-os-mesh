# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=848cf0b18d51e0170e0d1537aec3505a

# Railway
RAILWAY_TOKEN=

# Vercel
VERCEL_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ─── OAuth / OIDC ──────────────────────────────────────────────────────────────
# Point these at your self-hosted Keycloak (or any OIDC provider).
# When OAUTH_JWKS_URL is set, the /ws and /broadcast endpoints require a
# valid Bearer JWT signed by this provider.
#
# Keycloak example:
#   OAUTH_ISSUER=https://<tailscale-host>/realms/blackroad
#   OAUTH_JWKS_URL=https://<tailscale-host>/realms/blackroad/protocol/openid-connect/certs
#   OAUTH_AUDIENCE=blackroad-mesh
#
OAUTH_ISSUER=
OAUTH_JWKS_URL=
OAUTH_AUDIENCE=

# ─── Self-hosted LLM proxy ─────────────────────────────────────────────────────
# API calls to /api/proxy/llm/* are forwarded here instead of going to
# OpenAI / Anthropic / etc. directly.
# Examples: Ollama (http://ollama:11434), vLLM, LiteLLM, LocalAI
#
LLM_BASE_URL=
LLM_API_KEY=

# ─── Tailscale ─────────────────────────────────────────────────────────────────
# The Tailscale domain for your network (e.g. "tailXXXXX.ts.net" or a MagicDNS
# base domain).  Used to build internal service URLs.
#
TAILSCALE_DOMAIN=

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Service Mesh ──────────────────────────────────────────────────────────────
SERVICE_REGISTRY_URL=https://api.blackroad.io/registry
SERVICE_NAME=blackroad-os-mesh
SERVICE_ORG=BlackRoad-OS
